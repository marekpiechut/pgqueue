	"devDependencies": {
		"@types/chai": "^4.3.6",
		"@types/chai-as-promised": "^7.1.6",
		"@types/chai-string": "^1.4.3",
		"@types/mocha": "^10.0.1",
		"@types/sinon": "^10.0.16"
	}
