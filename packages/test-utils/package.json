{
	"name": "@pgqueue/test-utils",
	"version": "1.0.0",
	"description": "Just some test utilities for pgqueue. Grab them if you want, but no support is provided.",
	"main": "lib/index.js",
	"types": "lib/index.d.ts",
	"files": [
		"lib"
	],
	"repository": "https://github.com/marekpiechut/pgqueue/packages/test-utils",
	"author": {
		"email": "marek@dayone.pl",
